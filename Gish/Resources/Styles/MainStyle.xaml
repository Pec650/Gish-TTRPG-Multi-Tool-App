<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    
    <Style TargetType="ContentPage" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="#EEF5DB" />
    </Style>
    
    <Style TargetType="VerticalStackLayout">
        <Setter Property="VerticalOptions" Value="Center"></Setter>
        <Setter Property="HorizontalOptions" Value="Center"></Setter>
    </Style>
    
    <Style TargetType="Border">
        <Setter Property="Stroke" Value="Gray"></Setter>
        <Setter Property="StrokeThickness" Value="1"></Setter>
    </Style>
    
    <Style TargetType="Entry">
        <Setter Property="TextColor" Value="Black"></Setter>
        <Setter Property="PlaceholderColor" Value="Gray"></Setter>
        <Setter Property="BackgroundColor" Value="Transparent"></Setter>
    </Style>
    
    <Style x:Key="TitleText" TargetType="Label">
        <Setter Property="TextColor" Value="Black"></Setter>
        <Setter Property="FontSize" Value="64"></Setter>
        <Setter Property="HorizontalOptions" Value="Center"></Setter>
        <Setter Property="HorizontalTextAlignment" Value="Center"></Setter>
        <Setter Property="FontFamily" Value="AveriaLibre-Bold.ttf"></Setter>
    </Style>
    
    <Style x:Key="InputTextLabel" TargetType="Label">
        <Setter Property="TextColor" Value="Black"></Setter>
        <Setter Property="FontSize" Value="25"></Setter>
        <Setter Property="HorizontalOptions" Value="Fill"></Setter>
        <Setter Property="HorizontalTextAlignment" Value="Start"></Setter>
        <Setter Property="FontFamily" Value="Harmattan-Bold.ttf"></Setter>
        <Setter Property="Margin" Value="0, 0, 0, -30"></Setter>
    </Style>
    
    <Style x:Key="InputTextEntryBorder" TargetType="Border">
        <Setter Property="StrokeShape" Value="RoundRectangle 5"></Setter>
        <Setter Property="StrokeThickness" Value="0"></Setter>
        <Setter Property="Padding" Value="10, 0"></Setter>
        <Setter Property="BackgroundColor" Value="White"></Setter>
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="Black"
                        Offset="0, 0"
                        Radius="4"
                        Opacity="0.25"/>
            </Setter.Value>
        </Setter>
    </Style>
    
    <Style x:Key="InputTextEntry" TargetType="Entry">
        <Setter Property="TextColor" Value="Black"></Setter>
        <Setter Property="PlaceholderColor" Value="#747474"></Setter>
        <Setter Property="BackgroundColor" Value="White"></Setter>
        <Setter Property="FontSize" Value="20"></Setter>
        <Setter Property="HorizontalOptions" Value="Fill"></Setter>
        <Setter Property="HorizontalTextAlignment" Value="Start"></Setter>
        <Setter Property="VerticalOptions" Value="Center"></Setter>
        <Setter Property="VerticalTextAlignment" Value="Center"></Setter>
        <Setter Property="FontFamily" Value="Harmattan-Bold.ttf"></Setter>
    </Style>
    
    <Style x:Key="PasswordEyeIcon" TargetType="ImageButton">
        <Setter Property="Source" Value="show_pass_eye.png"></Setter>
        <Setter Property="HeightRequest" Value="20"></Setter>
        <Setter Property="HorizontalOptions" Value="End"></Setter>
        <Setter Property="VerticalOptions" Value="Center"></Setter>
    </Style>
    
    <Style x:Key="InputErrorText" TargetType="Label">
        <Setter Property="TextColor" Value="Red"></Setter>
        <Setter Property="HorizontalOptions" Value="Fill"></Setter>
        <Setter Property="HorizontalTextAlignment" Value="Start"></Setter>
        <Setter Property="FontSize" Value="25"></Setter>
        <Setter Property="FontFamily" Value="Harmattan-Bold.ttf"></Setter>
    </Style>
    
    <Style x:Key="RedBtn"  TargetType="Button">
        <Setter Property="TextColor" Value="White"></Setter>
        <Setter Property="BackgroundColor" Value="#FE5F55"></Setter>
        <Setter Property="FontFamily" Value="Faustina-Bold.ttf"></Setter>
        <Setter Property="CornerRadius" Value="10"></Setter>
        <Setter Property="FontSize" Value="25"></Setter>
        <Setter Property="TextTransform" Value="Uppercase"></Setter>
        <Setter Property="CharacterSpacing" Value="5"></Setter>
        <Setter Property="HorizontalOptions" Value="Fill"></Setter>
        <Setter Property="Padding" Value="0, 10"></Setter>
    </Style>
    
    <Style x:Key="SubmitBtn" TargetType="Button">
        <Setter Property="TextColor" Value="FloralWhite"></Setter>
        <Setter Property="BackgroundColor" Value="DarkSlateBlue"></Setter>
    </Style>
    
</ResourceDictionary>    