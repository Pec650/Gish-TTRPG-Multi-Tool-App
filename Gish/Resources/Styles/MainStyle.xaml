<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- PAGE -->
    <Style TargetType="ContentPage" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{StaticResource PageBackground}" />
    </Style>

    <!-- SECTION HEADER -->
    <Style x:Key="SectionHeader" TargetType="Label">
        <Setter Property="FontSize"        Value="20" />
        <Setter Property="FontAttributes"  Value="Bold" />
        <Setter Property="TextColor"       Value="{StaticResource AccentGreen}" />
        <Setter Property="FontFamily"      Value="AveriaLibre-Bold.ttf" />
        <Setter Property="Margin"          Value="0,8,0,0" />
    </Style>

    <!-- PAGE TITLE -->
    <Style x:Key="PageTitle" TargetType="Label">
        <Setter Property="FontSize"       Value="26" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor"      Value="{StaticResource TextDark}" />
        <Setter Property="FontFamily"     Value="AveriaLibre-Bold.ttf" />
    </Style>
    
    <!-- PAGE SUBTITLE -->
    <Style x:Key="SubTitle" TargetType="Label">
        <Setter Property="FontSize"       Value="32"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor"      Value="#4F6367"/>
        <Setter Property="FontFamily"     Value="Faustina-Bold.ttf"/>
    </Style>
    
    <!-- PAGE SUBTITLE TEXT -->
    <Style x:Key="SubTitleText" TargetType="Label">
        <Setter Property="FontSize"       Value="18"/>
        <Setter Property="TextColor"      Value="#4F6367"/>
        <Setter Property="FontFamily"     Value="Commissioner-Medium.ttf"/>
    </Style>
    
    <!-- PROFILE PICTURE STYLE -->
    <Style x:Key="ProfilePicture" TargetType="ImageButton">
        <Setter Property="CornerRadius"       Value="100"/>
        <Setter Property="BorderColor"       Value="#424C44"/>
        <Setter Property="BorderWidth"      Value="3"/>
    </Style>
    
    <!-- OUTER CARD -->
    <Style x:Key="CardOuter" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource CardOuter}" />
        <Setter Property="Stroke"          Value="Transparent" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="StrokeShape"     Value="RoundRectangle 12" />
        <Setter Property="Padding"         Value="8" />
    </Style>

    <!-- INNER CARD -->
    <Style x:Key="CardInner" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource CardInner}" />
        <Setter Property="Stroke"          Value="Transparent" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="StrokeShape"     Value="RoundRectangle 8" />
        <Setter Property="Padding"         Value="10" />
    </Style>

    <!-- ITEM TITLE -->
    <Style x:Key="ItemTitle" TargetType="Label">
        <Setter Property="FontSize"       Value="24" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor"      Value="{StaticResource TextDark}" />
        <Setter Property="FontFamily"     Value="Harmattan-Bold.ttf" />
    </Style>

    <!-- ITEM SUBTITLE -->
    <Style x:Key="ItemSubtitle" TargetType="Label">
        <Setter Property="FontSize"   Value="16" />
        <Setter Property="TextColor"  Value="{StaticResource TextMid}" />
        <Setter Property="FontFamily" Value="Harmattan-Bold.ttf" />
    </Style>

    <!-- CHEVRON -->
    <Style x:Key="Chevron" TargetType="Label">
        <Setter Property="FontSize"       Value="50" />
        <Setter Property="TextColor"      Value="{StaticResource TextMid}" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>

    <!-- PRIMARY BUTTON -->
    <Style x:Key="PrimaryBtn" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource AccentGreen}" />
        <Setter Property="TextColor"       Value="{StaticResource White}" />
        <Setter Property="FontFamily"      Value="Faustina-Bold.ttf" />
        <Setter Property="CornerRadius"    Value="8" />
        <Setter Property="FontSize"        Value="15" />
        <Setter Property="Padding"         Value="12,8" />
    </Style>

    <!-- DANGER BUTTON -->
    <Style x:Key="DangerBtn" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource AccentRed}" />
        <Setter Property="TextColor"       Value="{StaticResource White}" />
        <Setter Property="FontFamily"      Value="Faustina-Bold.ttf" />
        <Setter Property="CornerRadius"    Value="8" />
        <Setter Property="FontSize"        Value="15" />
        <Setter Property="Padding"         Value="12,8" />
    </Style>

    <!-- DICE BUTTON -->
    <Style x:Key="DiceBtn" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource CardInner}" />
        <Setter Property="TextColor"       Value="{StaticResource TextDark}" />
        <Setter Property="FontFamily"      Value="Faustina-Bold.ttf" />
        <Setter Property="CornerRadius"    Value="8" />
        <Setter Property="FontSize"        Value="14" />
        <Setter Property="Padding"         Value="10,6" />
        <Setter Property="Margin"          Value="4" />
    </Style>

    <!-- ROLL LOG BUTTON -->
    <Style x:Key="RollLogBtn" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource RollLogGreen}" />
        <Setter Property="Stroke"          Value="Transparent" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="StrokeShape"     Value="RoundRectangle 8" />
        <Setter Property="Padding"         Value="10,8" />
    </Style>
    
    <!-- TOOLS BUTTON -->
    <Style x:Key="ToolsButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="#EEE0CB" />
        <Setter Property="BorderColor"     Value="#839788" />
        <Setter Property="BorderWidth"     Value="5" />
        <Setter Property="CornerRadius"    Value="15" />
        <Setter Property="FontSize"        Value="24" />
        <Setter Property="FontAttributes"  Value="Bold" />
        <Setter Property="TextColor"       Value="{StaticResource TextDark}" />
        <Setter Property="FontFamily"      Value="Harmattan-Bold.ttf" />
        <Setter Property="Margin"          Value="0, 2" />
    </Style>

    <!-- AUTH STYLES -->
    <Style x:Key="TitleText" TargetType="Label">
        <Setter Property="TextColor"            Value="{StaticResource TextDark}" />
        <Setter Property="FontSize"             Value="64" />
        <Setter Property="HorizontalOptions"    Value="Center" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
        <Setter Property="FontFamily"           Value="AveriaLibre-Bold.ttf" />
    </Style>

    <Style x:Key="InputTextLabel" TargetType="Label">
        <Setter Property="TextColor"            Value="{StaticResource TextDark}" />
        <Setter Property="FontSize"             Value="25" />
        <Setter Property="HorizontalOptions"    Value="Fill" />
        <Setter Property="HorizontalTextAlignment" Value="Start" />
        <Setter Property="FontFamily"           Value="Harmattan-Bold.ttf" />
        <Setter Property="Margin"               Value="0,0,0,-30" />
    </Style>

    <Style x:Key="InputTextEntryBorder" TargetType="Border">
        <Setter Property="StrokeShape"     Value="RoundRectangle 5" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="Padding"         Value="10,0" />
        <Setter Property="BackgroundColor" Value="{StaticResource White}" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="Black" Offset="0,0" Radius="4" Opacity="0.25"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="InputTextEntry" TargetType="Entry">
        <Setter Property="TextColor"            Value="{StaticResource TextDark}" />
        <Setter Property="PlaceholderColor"     Value="#747474" />
        <Setter Property="BackgroundColor"      Value="{StaticResource White}" />
        <Setter Property="FontSize"             Value="20" />
        <Setter Property="HorizontalOptions"    Value="Fill" />
        <Setter Property="HorizontalTextAlignment" Value="Start" />
        <Setter Property="VerticalOptions"      Value="Center" />
        <Setter Property="FontFamily"           Value="Harmattan-Bold.ttf" />
    </Style>

    <Style x:Key="PasswordEyeIcon" TargetType="ImageButton">
        <Setter Property="Source"           Value="show_pass_eye.png" />
        <Setter Property="HeightRequest"    Value="20" />
        <Setter Property="HorizontalOptions" Value="End" />
        <Setter Property="VerticalOptions"  Value="Center" />
    </Style>

    <Style x:Key="InputErrorText" TargetType="Label">
        <Setter Property="TextColor"            Value="Red" />
        <Setter Property="HorizontalOptions"    Value="Fill" />
        <Setter Property="HorizontalTextAlignment" Value="Start" />
        <Setter Property="FontSize"             Value="25" />
        <Setter Property="FontFamily"           Value="Harmattan-Bold.ttf" />
    </Style>

    <Style x:Key="RedBtn" TargetType="Button">
        <Setter Property="TextColor"       Value="{StaticResource White}" />
        <Setter Property="BackgroundColor" Value="#FE5F55" />
        <Setter Property="FontFamily"      Value="Faustina-Bold.ttf" />
        <Setter Property="CornerRadius"    Value="10" />
        <Setter Property="FontSize"        Value="25" />
        <Setter Property="TextTransform"   Value="Uppercase" />
        <Setter Property="CharacterSpacing" Value="5" />
        <Setter Property="HorizontalOptions" Value="Fill" />
        <Setter Property="Padding"         Value="0,10" />
    </Style>

    <!-- Default Border reset (so CardOuter/CardInner override cleanly) -->
    <Style TargetType="Border">
        <Setter Property="Stroke"          Value="Transparent" />
        <Setter Property="StrokeThickness" Value="0" />
    </Style>

    <!-- Default Entry -->
    <Style TargetType="Entry">
        <Setter Property="TextColor"       Value="{StaticResource TextDark}" />
        <Setter Property="PlaceholderColor" Value="#747474" />
        <Setter Property="BackgroundColor" Value="Transparent" />
    </Style>

</ResourceDictionary>