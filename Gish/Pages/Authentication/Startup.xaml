<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Gish.Pages.Authentication.Startup">
    <ContentPage.Content>
        <Grid ColumnDefinitions="0.1*, 0.8*, 0.1*">
            <VerticalStackLayout Grid.Column="1" Spacing="30" HorizontalOptions="Fill">
            
                <Label Text="Gish"
                       Margin="0, 0, 0, 50"
                       Style="{StaticResource TitleText}"></Label>
            
                <Button x:Name="GoToLoginBtn"
                        Text="Login"
                        Style="{StaticResource RedBtn}"
                        Clicked="RedirectToLogin"></Button>
            
                <Button x:Name="GoToSignUpBtn"
                        Text="Signup"
                        Style="{StaticResource RedBtn}"
                        Clicked="RedirectToSignup"></Button>
            
            </VerticalStackLayout>
        </Grid>
    </ContentPage.Content>
</ContentPage>