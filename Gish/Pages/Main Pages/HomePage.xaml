<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Gish.Pages.MainPages.HomePage"
             Title="Home"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource TabBar}">

    <Grid RowDefinitions="Auto,*">

        <!-- HEADER -->
        <Grid Grid.Row="0"
              x:Name="Header"
              Padding="16,32,16,16"
              ColumnDefinitions="*,Auto">
            <Label Style="{StaticResource PageTitle}"
                   Text="Welcome, User"
                   TextColor="{StaticResource TextDark}"
                   VerticalOptions="Center"/>
            <HorizontalStackLayout Grid.Column="1" Spacing="10" VerticalOptions="Center">
                <Image Source="profile_icon.png" WidthRequest="36" HeightRequest="36"/>
                <Label Text="≡" FontSize="26" TextColor="{StaticResource TextDark}" VerticalOptions="Center"/>
            </HorizontalStackLayout>
        </Grid>

        <!-- CREAM CONTENT AREA -->
        <Border Grid.Row="1"
                BackgroundColor="{StaticResource PageBackground}"
                Stroke="Transparent">
            <ScrollView>
                <VerticalStackLayout Padding="16,32,16,0" Spacing="4"
                                     HorizontalOptions="Fill"
                                     VerticalOptions="Start">

                    <!-- RECENT HOMEBREW -->
                    <Label Text="Recent Homebrew" Style="{StaticResource SectionHeader}"/>
                    <Border Style="{StaticResource CardOuter}" Margin="0,6,0,0">
                        <VerticalStackLayout Spacing="6">
                            <CollectionView x:Name="RecentHomebrewList"
                                            SelectionMode="Single"
                                            SelectionChanged="OnHomebrewSelected">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource CardInner}" Margin="0,0,0,6">
                                            <Grid ColumnDefinitions="36,*,Auto">
                                                <Image Source="sword_icon.png" WidthRequest="28" HeightRequest="28" VerticalOptions="Center"/>
                                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                                    <Label Text="{Binding Name}" Style="{StaticResource ItemTitle}"/>
                                                    <HorizontalStackLayout Spacing="16">
                                                        <Label Text="{Binding SubType}" Style="{StaticResource ItemSubtitle}"/>
                                                        <Label Text="{Binding System}"  Style="{StaticResource ItemSubtitle}"/>
                                                    </HorizontalStackLayout>
                                                </VerticalStackLayout>
                                                <Label Grid.Column="2" Text="›" Style="{StaticResource Chevron}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>

                    <!-- QUICK ROLL -->
                    <Label Text="Quick Roll" Style="{StaticResource SectionHeader}" Margin="0,16,0,0"/>
                    <Border Style="{StaticResource CardOuter}" Margin="0,6,0,0">
                        <VerticalStackLayout Spacing="10">

                            <Grid ColumnDefinitions="64,*">
                                <!-- D20 big button -->
                                <ImageButton Source="dice/d20.svg"
                                            WidthRequest="56" HeightRequest="56"
                                            HorizontalOptions="Start"
                                            Clicked="OnDiceClicked" CommandParameter="20"
                                            BackgroundColor="Transparent"/>

                                <!-- Dice row -->
                                <FlexLayout Grid.Column="1" Wrap="Wrap" JustifyContent="Start" AlignItems="Center">
                                    <ImageButton Source="dice/d4.svg"   WidthRequest="64" HeightRequest="64" Margin="4"
                                                Clicked="OnDiceClicked" CommandParameter="4"  BackgroundColor="Transparent"/>
                                    <ImageButton Source="dice/d6.svg"   WidthRequest="64" HeightRequest="64" Margin="4"
                                                Clicked="OnDiceClicked" CommandParameter="6"  BackgroundColor="Transparent"/>
                                    <ImageButton Source="dice/d8.svg"   WidthRequest="64" HeightRequest="64" Margin="4"
                                                Clicked="OnDiceClicked" CommandParameter="8"  BackgroundColor="Transparent"/>
                                    <ImageButton Source="dice/d10.svg"  WidthRequest="64" HeightRequest="64" Margin="4"
                                                Clicked="OnDiceClicked" CommandParameter="10" BackgroundColor="Transparent"/>
                                    <ImageButton Source="dice/d12.svg"  WidthRequest="64" HeightRequest="64" Margin="4"
                                                Clicked="OnDiceClicked" CommandParameter="12" BackgroundColor="Transparent"/>
                                    <ImageButton Source="dice/d100.svg" WidthRequest="64" HeightRequest="64" Margin="4"
                                                Clicked="OnDiceClicked" CommandParameter="100" BackgroundColor="Transparent"/>
                                </FlexLayout>
                            </Grid>

                            <Label x:Name="RollResultLabel" Text="Select a die and roll"
                                   FontSize="16" TextColor="{StaticResource TextDark}"
                                   HorizontalOptions="Center"/>

                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                <Border Style="{StaticResource RollLogBtn}">
                                    <Label Text="Roll Log" HorizontalOptions="Center"
                                           FontSize="14" TextColor="{StaticResource TextDark}"
                                           FontFamily="Harmattan-Bold.ttf"/>
                                </Border>
                                <HorizontalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                                    <VerticalStackLayout VerticalOptions="Center">
                                        <Label Text="Modifier" FontSize="11"
                                               TextColor="{StaticResource TextDark}"
                                               HorizontalOptions="Center"/>
                                        <HorizontalStackLayout Spacing="4">
                                            <Button x:Name="DisadvantageBtn" Text="D"
                                                    Style="{StaticResource DangerBtn}"
                                                    Clicked="OnModifierClicked" CommandParameter="D"
                                                    FontSize="13" Padding="8,4" Margin="0"/>
                                            <Button x:Name="NormalBtn" Text="●"
                                                    Style="{StaticResource DiceBtn}"
                                                    Clicked="OnModifierClicked" CommandParameter="N"
                                                    FontSize="13" Padding="8,4" Margin="0"/>
                                            <Button x:Name="AdvantageBtn" Text="A"
                                                    Style="{StaticResource PrimaryBtn}"
                                                    Clicked="OnModifierClicked" CommandParameter="A"
                                                    FontSize="13" Padding="8,4" Margin="0"/>
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                    <Border BackgroundColor="{StaticResource White}"
                                            StrokeShape="RoundRectangle 6"
                                            Stroke="Transparent" Padding="6,4">
                                        <Grid RowDefinitions="*,*" ColumnDefinitions="30,20">
                                            <Label x:Name="BonusLabel" Text="0"
                                                   FontSize="14" TextColor="{StaticResource TextDark}"
                                                   HorizontalOptions="Center" VerticalOptions="Center"
                                                   Grid.RowSpan="2"/>
                                            <Button Text="+" Grid.Column="1" Grid.Row="0"
                                                    Clicked="OnBonusUp"
                                                    FontSize="10" Padding="0" Margin="0"
                                                    BackgroundColor="Transparent"
                                                    TextColor="{StaticResource TextDark}"/>
                                            <Button Text="-" Grid.Column="1" Grid.Row="1"
                                                    Clicked="OnBonusDown"
                                                    FontSize="10" Padding="0" Margin="0"
                                                    BackgroundColor="Transparent"
                                                    TextColor="{StaticResource TextDark}"/>
                                        </Grid>
                                    </Border>
                                </HorizontalStackLayout>
                            </Grid>

                            <Button Text="ROLL" Style="{StaticResource DangerBtn}"
                                    Clicked="OnRollClicked" FontSize="18"
                                    HorizontalOptions="Fill"/>

                            <CollectionView x:Name="RollLogList" HeightRequest="120">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Label Text="{Binding .}" Padding="4,2"
                                               FontSize="13" TextColor="{StaticResource TextMid}"
                                               FontFamily="Harmattan-Bold.ttf"/>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                        </VerticalStackLayout>
                    </Border>

                    <!-- SESSION REMINDER -->
                    <Label Text="Session Reminder" Style="{StaticResource SectionHeader}" Margin="0,16,0,0"/>
                    <Border Style="{StaticResource CardOuter}" Margin="0,6,0,16">
                        <Grid ColumnDefinitions="48,*">
                            <Image Source="discord_icon.png" WidthRequest="36" HeightRequest="36" VerticalOptions="Center"/>
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label x:Name="SessionTitle" Text="D&amp;D Session"
                                       FontSize="20" FontAttributes="Bold"
                                       TextColor="{StaticResource TextDark}"
                                       FontFamily="AveriaLibre-Bold.ttf"
                                       HorizontalOptions="Center"/>
                                <Label x:Name="SessionDate" Text="May 2, 2026"
                                       FontSize="13" TextColor="{StaticResource TextDark}"
                                       HorizontalOptions="Center"/>
                                <Label x:Name="SessionTime" Text="Time Start: 1:30 PM"
                                       FontSize="13" TextColor="{StaticResource TextDark}"
                                       HorizontalOptions="Center"/>
                                <Label x:Name="SessionCampaign" Text="Campaign: D&amp;D Campaign Title"
                                       FontSize="12" TextColor="{StaticResource AccentGreen}"
                                       HorizontalOptions="Center"/>
                                <Label x:Name="SessionSystem" Text="RPG System: Dungeons &amp; Dragons 5.5e"
                                       FontSize="11" TextColor="{StaticResource TextMid}"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>
        </Border>

    </Grid>
</ContentPage>