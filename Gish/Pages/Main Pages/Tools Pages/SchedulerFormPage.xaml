<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Gish.Pages.ToolPages.SchedulerFormPage"
             BackgroundColor="{StaticResource PageBackground}">
    
    <ContentPage.Content>
        <Grid RowDefinitions="Auto, *" Padding="0" RowSpacing="0">
            <ScrollView Grid.Row="1" Padding="24">
                <VerticalStackLayout Spacing="18">
                    
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Session Title" FontAttributes="Bold" TextColor="#424C44"/>
                        <Entry x:Name="TitleEntry" Placeholder="e.g., Epic Boss Fight Finale" BackgroundColor="White"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="RPG System" FontAttributes="Bold" TextColor="#424C44"/>
                        <Picker x:Name="SystemPicker" Title="Select an RPG System" BackgroundColor="White" SelectedIndexChanged="OnSystemPickerChanged"/>
                        <Entry x:Name="CustomSystemEntry" Placeholder="Type custom system (e.g., Cyberpunk Red)" BackgroundColor="White" IsVisible="False" Margin="0,5,0,0"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="Campaign Title" FontAttributes="Bold" TextColor="#424C44"/>
                        <Picker x:Name="CampaignPicker" Title="Select a Campaign" BackgroundColor="White" SelectedIndexChanged="OnCampaignPickerChanged"/>
                        <Entry x:Name="CustomCampaignEntry" Placeholder="Type custom campaign title" BackgroundColor="White" IsVisible="False" Margin="0,5,0,0"/>
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                        <VerticalStackLayout Grid.Column="0" Spacing="5">
                            <Label Text="Date" FontAttributes="Bold" TextColor="#424C44"/>
                            <DatePicker x:Name="SessionDatePicker" MinimumDate="2026-01-01" BackgroundColor="White"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="5">
                            <Label Text="Start Time" FontAttributes="Bold" TextColor="#424C44"/>
                            <TimePicker x:Name="SessionTimePicker" BackgroundColor="White"/>
                        </VerticalStackLayout>
                    </Grid>

                    <Grid ColumnDefinitions="*, Auto" Margin="0,10,0,0" VerticalOptions="Center">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Set Session Reminder" FontAttributes="Bold" TextColor="#424C44"/>
                            <Label Text="Notify players 30 minutes before game time" FontSize="12" TextColor="#5D6660"/>
                        </VerticalStackLayout>
                        <Switch x:Name="ReminderSwitch" 
                                Grid.Column="1" 
                                IsToggled="True" 
                                OnColor="#A2C9B4" 
                                ThumbColor="#424C44"/>
                    </Grid>

                    <Button Text="Save Session Layout" 
                            BackgroundColor="#A2C9B4" 
                            TextColor="#1E2420" 
                            FontAttributes="Bold"
                            Margin="0,20,0,0"
                            HeightRequest="50"
                            Clicked="OnSaveClicked"/>
                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </ContentPage.Content>
</ContentPage>