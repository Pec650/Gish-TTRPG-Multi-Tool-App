<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Gish.Pages.Controls"
             x:Class="Gish.Pages.Main_Pages.MainContainerPage"
             BackgroundColor="{StaticResource TabBar}"
             Padding="0">

    <Grid RowDefinitions="Auto, *" 
          SafeAreaEdges="None" 
          Padding="0" 
          RowSpacing="0" 
          Margin="0">

        <controls:CustomHeader x:Name="AppHeader" x:FieldModifier="public" Grid.Row="0" Title="Home" />

        <Grid Grid.Row="1" Margin="0" Padding="0" SafeAreaEdges="None">
            
            <Grid x:Name="ContentArea" Margin="0" Padding="0,0,0,64"/>

            <controls:CustomTabBar x:Name="AppTabBar" 
                                   VerticalOptions="End" 
                                   HeightRequest="80"
                                   ActiveTab="Home"/>
        </Grid>
    </Grid>
</ContentPage>