<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Gish.Pages.Main_Pages.ToolsView"
             BackgroundColor="{StaticResource TabBar}">
        
    <ScrollView BackgroundColor="{StaticResource PageBackground}">
        <VerticalStackLayout Padding="20" Spacing="20">
            <Label Style="{StaticResource SubTitle}" Text="Tool Selection" HorizontalOptions="Center" />
            <Label Style="{StaticResource SubTitleText}" Text="Dice roller and other utilities" HorizontalOptions="Center" />
            
            <Button Text="Session Scheduler"
                    Style="{StaticResource ToolsButton}"
                    Clicked="GoToScheduler"/>
            
            <Button Text="Initiative Tracker"
                    Style="{StaticResource ToolsButton}"
                    Clicked="GoToInitiativeTracker"
            />
            
            <Button Text="CR Calculator"
                    Style="{StaticResource ToolsButton}"
            />
        </VerticalStackLayout>
    </ScrollView>
        
</ContentView>