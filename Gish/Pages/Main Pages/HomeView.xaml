<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Gish.Pages.Main_Pages.HomeView"
             BackgroundColor="{StaticResource TabBar}">

    <ScrollView BackgroundColor="{StaticResource PageBackground}">
        <VerticalStackLayout Padding="16,20,16,16" Spacing="16">

            <CollectionView x:Name="RecentSessionItem" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Session Reminder" Style="{StaticResource SectionHeader}"/>
                            <Border Style="{StaticResource CardOuter}">
                                <VerticalStackLayout Spacing="4">
                                    <Border Style="{StaticResource CardInner}" HorizontalOptions="Fill">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="GoToScheduler"></TapGestureRecognizer>
                                        </Border.GestureRecognizers>
                                        
                                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" Padding="4">
                                            <Border HeightRequest="80" 
                                                    WidthRequest="80"
                                                    Stroke="#839788"
                                                    StrokeThickness="5"
                                                    StrokeShape="RoundRectangle 40"
                                                    HorizontalOptions="Start"
                                                    VerticalOptions="Center">
            
                                                <Image Source="discord_icon.png"
                                                       Aspect="AspectFill"
                                                       HeightRequest="80"
                                                       WidthRequest="80"/>
                                            </Border>
                                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                                <Label x:Name="SessionTitle" Text="{Binding Title}"
                                                       FontFamily="Faustina-Bold.ttf" FontSize="36" TextColor="{StaticResource TextDark}"
                                                       HorizontalOptions="End" HorizontalTextAlignment="End" LineBreakMode="TailTruncation" MaxLines="1" WidthRequest="250"/>
                                                <Label x:Name="SessionDate" Text="{Binding Date, StringFormat='{0:MMMM d, yyyy}'}"
                                                       Style="{StaticResource ItemSubtitle}"
                                                       HorizontalOptions="End"/>
                                                <Label x:Name="SessionTime"
                                                       Style="{StaticResource ItemSubtitle}"
                                                       FontSize="20"
                                                       HorizontalOptions="End">
                                                    <Label.FormattedText>
                                                        <FormattedString>
                                                            <Span Text="Time Start: " Style="{StaticResource ItemSubtitle}" FontSize="20" />
                                                            <Span Text="{Binding FormattedStartTime}" Style="{StaticResource ItemSubtitle}" FontSize="20" />
                                                        </FormattedString>
                                                    </Label.FormattedText>
                                                </Label>
                                            </VerticalStackLayout>
                                        </Grid>
                                    </Border>
                                    
                                    <!-- <Label x:Name="SessionCampaign" Text="Campaign: D&amp;D Campaign Title" -->
                                    <!--        Style="{StaticResource ItemSubtitle}" Margin="0,4,4,0" -->
                                    <!--        HorizontalOptions="End" TextColor="White" -->
                                    <!--        FontSize="21"/> -->
                                    <!-- <Label x:Name="SessionSystem" Text="RPG System: Dungeons &amp; Dragons 5.5e" -->
                                    <!--        Style="{StaticResource ItemSubtitleText}" Margin="0,0,4,4" -->
                                    <!--        HorizontalOptions="End" TextColor="White" -->
                                    <!--        FontSize="15"/> -->
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- QUICK ROLL -->
            <VerticalStackLayout Spacing="6">
                <Label Text="Quick Roll" Style="{StaticResource SectionHeader}"/>
                <Border Style="{StaticResource CardOuter}">
                    <VerticalStackLayout Spacing="12" Padding="8">

                        <!-- Dice area — switches between dice grid and d20 drawer -->
                        <Border Style="{StaticResource CardInner}" Padding="8">
                            <Grid>

                                <!-- DEFAULT: dice grid view -->
                                <Grid x:Name="DiceGridView"
                                      ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto"
                                      ColumnSpacing="6" RowSpacing="6"
                                      Margin="68,20,52,0">
                                    <ImageButton Grid.Row="0" Grid.Column="0" Source="dice/d4.svg"
                                                 WidthRequest="52" HeightRequest="52"
                                                 BackgroundColor="Transparent"
                                                 Clicked="OnDiceClicked" CommandParameter="4"/>
                                    <ImageButton Grid.Row="0" Grid.Column="1" Source="dice/d6.svg"
                                                 WidthRequest="52" HeightRequest="52"
                                                 BackgroundColor="Transparent"
                                                 Clicked="OnDiceClicked" CommandParameter="6"/>
                                    <ImageButton Grid.Row="0" Grid.Column="2" Source="dice/d8.svg"
                                                 WidthRequest="52" HeightRequest="52"
                                                 BackgroundColor="Transparent"
                                                 Clicked="OnDiceClicked" CommandParameter="8"/>
                                    <ImageButton Grid.Row="1" Grid.Column="0" Source="dice/d10.svg"
                                                 WidthRequest="52" HeightRequest="52"
                                                 BackgroundColor="Transparent"
                                                 Clicked="OnDiceClicked" CommandParameter="10"/>
                                    <ImageButton Grid.Row="1" Grid.Column="1" Source="dice/d12.svg"
                                                 WidthRequest="52" HeightRequest="52"
                                                 BackgroundColor="Transparent"
                                                 Clicked="OnDiceClicked" CommandParameter="12"/>
                                    <ImageButton Grid.Row="1" Grid.Column="2" Source="dice/d100.svg"
                                                 WidthRequest="52" HeightRequest="52"
                                                 BackgroundColor="Transparent"
                                                 Clicked="OnDiceClicked" CommandParameter="100"/>
                                </Grid>

                                <!-- D20 DRAWER: replaces dice grid when open -->
                                <Grid x:Name="D20DrawerView" IsVisible="False"
                                      RowDefinitions="Auto, Auto"
                                      RowSpacing="12"
                                      Margin="0,8,52,8">

                                    <Label Grid.Row="0"
                                           Text="d20 Roll"
                                           FontFamily="Faustina-Bold.ttf"
                                           FontSize="20"
                                           TextColor="{StaticResource TextDark}"
                                           HorizontalOptions="Center"/>

                                    <VerticalStackLayout Grid.Row="1" Spacing="12" HorizontalOptions="Fill">

                                        <Label x:Name="D20CountDisplay"
                                               Text="1d20"
                                               FontFamily="Faustina-Bold.ttf"
                                               FontSize="36"
                                               TextColor="{StaticResource TextDark}"
                                               HorizontalOptions="Center"/>

                                        <Grid ColumnDefinitions="*, Auto, *" ColumnSpacing="12" HorizontalOptions="Fill">
                                            <Button Grid.Column="0" Text="−"
                                                    Clicked="OnDecrementD20Pool"
                                                    FontSize="28" FontAttributes="Bold"
                                                    HeightRequest="56"
                                                    BackgroundColor="#E5DEC9"
                                                    TextColor="{StaticResource TextDark}"
                                                    CornerRadius="8"/>
                                            <Button Grid.Column="2" Text="+"
                                                    Clicked="OnIncrementD20Pool"
                                                    FontSize="28" FontAttributes="Bold"
                                                    HeightRequest="56"
                                                    BackgroundColor="#E5DEC9"
                                                    TextColor="{StaticResource TextDark}"
                                                    CornerRadius="8"/>
                                        </Grid>

                                        <Button Text="ROLL d20"
                                                Clicked="OnExecuteD20DrawerRoll"
                                                FontFamily="Faustina-Bold.ttf"
                                                FontSize="18"
                                                HeightRequest="52"
                                                BackgroundColor="{StaticResource AccentRed}"
                                                TextColor="White"
                                                CornerRadius="8"
                                                HorizontalOptions="Fill"/>
                                    </VerticalStackLayout>
                                </Grid>

                                <!-- Floating d20 button — top left -->
                                <Border StrokeShape="Ellipse"
                                        BackgroundColor="{StaticResource AccentRed}"
                                        WidthRequest="72" HeightRequest="72"
                                        HorizontalOptions="Start" VerticalOptions="Start">
                                    <Grid>
                                        <ImageButton Source="dice/d20.svg"
                                                     WidthRequest="52" HeightRequest="52"
                                                     BackgroundColor="Transparent"
                                                     HorizontalOptions="Center" VerticalOptions="Center"
                                                     Clicked="OnToggleD20Drawer"/>
                                        <Label x:Name="D20DrawerChevron" Text="▾"
                                               FontSize="10" FontAttributes="Bold"
                                               TextColor="{StaticResource TextDark}" Opacity="0.8"
                                               HorizontalOptions="End" VerticalOptions="End"
                                               Margin="0,0,4,4"
                                               InputTransparent="True"/>
                                    </Grid>
                                </Border>

                                <!-- Floating X — top right, clears queue and closes d20 drawer -->
                                <Border StrokeShape="Ellipse"
                                        BackgroundColor="{StaticResource AccentRed}"
                                        WidthRequest="44" HeightRequest="44"
                                        HorizontalOptions="End" VerticalOptions="Start"
                                        Margin="0,4,4,0">
                                    <Label Text="✕" FontSize="18" FontAttributes="Bold"
                                           TextColor="White"
                                           HorizontalOptions="Center" VerticalOptions="Center">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnClearClicked"/>
                                        </Label.GestureRecognizers>
                                    </Label>
                                </Border>

                            </Grid>
                        </Border>

                        <!-- Dice queue label -->
                        <Label x:Name="DiceQueueLabel"
                               Text="Tap dice to add, press d20 to roll"
                               Style="{StaticResource ItemTitle}"
                               HorizontalTextAlignment="Center"
                               HorizontalOptions="Center"/>

                        <!-- Roll result -->
                        <Border x:Name="RollResult" IsVisible="False"
                                Style="{StaticResource CardInner}"
                                BackgroundColor="{StaticResource RollLogGreen}"
                                Padding="12,10">
                            <VerticalStackLayout x:Name="RollResultContainer" Spacing="4" HorizontalOptions="Center">
                                <Label x:Name="RollResultMainLabel" Text="Result: 0"
                                       Style="{StaticResource ItemTitle}"
                                       FontAttributes="Bold"
                                       FontSize="18"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Modifier + Bonus row -->
                        <Grid ColumnDefinitions="*, *" ColumnSpacing="12" Padding="4,0">

                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label Text="Modifier" FontSize="11"
                                       Style="{StaticResource ItemSubtitleText}"
                                       HorizontalOptions="Center"/>
                                <Border BackgroundColor="#E5DEC9"
                                        Stroke="Transparent"
                                        StrokeShape="RoundRectangle 8"
                                        HeightRequest="46"
                                        Padding="2" HorizontalOptions="Fill">
                                    <Grid ColumnDefinitions="*, *, *">
                                        <Border x:Name="DisadvBlock" Grid.Column="0"
                                                BackgroundColor="Transparent"
                                                StrokeShape="RoundRectangle 6" Stroke="Transparent">
                                            <Label x:Name="DisadvLabel" Text="D"
                                                   FontAttributes="Bold" FontSize="14"
                                                   HorizontalOptions="Center" VerticalOptions="Center"
                                                   TextColor="#AAB7B8"/>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnSelectDisadvantage"/>
                                            </Border.GestureRecognizers>
                                        </Border>
                                        <Border x:Name="NormalBlock" Grid.Column="1"
                                                BackgroundColor="#4A148C"
                                                StrokeShape="RoundRectangle 6" Stroke="Transparent">
                                            <Label x:Name="NormalLabel" Text="•"
                                                   FontAttributes="Bold" FontSize="16"
                                                   HorizontalOptions="Center" VerticalOptions="Center"
                                                   TextColor="White"/>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnSelectNormal"/>
                                            </Border.GestureRecognizers>
                                        </Border>
                                        <Border x:Name="AdvBlock" Grid.Column="2"
                                                BackgroundColor="Transparent"
                                                StrokeShape="RoundRectangle 6" Stroke="Transparent">
                                            <Label x:Name="AdvLabel" Text="A"
                                                   FontAttributes="Bold" FontSize="14"
                                                   HorizontalOptions="Center" VerticalOptions="Center"
                                                   TextColor="#AAB7B8"/>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnSelectAdvantage"/>
                                            </Border.GestureRecognizers>
                                        </Border>
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="Bonus" FontSize="11"
                                       Style="{StaticResource ItemSubtitleText}"
                                       HorizontalOptions="Center"/>
                                <Border BackgroundColor="#E5DEC9"
                                        Stroke="Transparent"
                                        StrokeShape="RoundRectangle 8"
                                        HeightRequest="46"
                                        Padding="2" HorizontalOptions="Fill">
                                    <Grid ColumnDefinitions="Auto, *, Auto">
                                        <Button Grid.Column="0" Text="−" Clicked="OnBonusDown"
                                                FontSize="16" FontAttributes="Bold"
                                                WidthRequest="40" HeightRequest="42"
                                                Padding="0" Margin="0"
                                                BackgroundColor="Transparent"
                                                TextColor="{StaticResource TextDark}"/>
                                        <Border Grid.Column="1" BackgroundColor="White"
                                                StrokeShape="RoundRectangle 6" Stroke="Transparent"
                                                Margin="2,0">
                                            <Label x:Name="BonusLabel" Text="0"
                                                   FontSize="15" FontAttributes="Bold"
                                                   TextColor="{StaticResource TextDark}"
                                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Border>
                                        <Button Grid.Column="2" Text="+" Clicked="OnBonusUp"
                                                FontSize="16" FontAttributes="Bold"
                                                WidthRequest="40" HeightRequest="42"
                                                Padding="0" Margin="0"
                                                BackgroundColor="Transparent"
                                                TextColor="{StaticResource TextDark}"/>
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>

                        </Grid>

                        <!-- ROLL LOG drawer toggle -->
                        <Border Style="{StaticResource RollLogBtn}" HorizontalOptions="Fill">
                            <Grid ColumnDefinitions="*, Auto">
                                <Label Text="ROLL LOG"
                                       FontSize="15" TextColor="{StaticResource White}"
                                       FontFamily="Faustina-Bold.ttf"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                                <Label x:Name="RollLogChevron" Grid.Column="1"
                                       Text="▼" FontSize="12"
                                       TextColor="{StaticResource White}"
                                       VerticalOptions="Center" Margin="0,0,4,0"/>
                            </Grid>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnRollLogToggled"/>
                            </Border.GestureRecognizers>
                        </Border>

                    </VerticalStackLayout>
                </Border>

                <!-- Roll log panel -->
                <Border x:Name="RollLogPanel"
                        IsVisible="False"
                        Style="{StaticResource CardOuter}">
                    <VerticalStackLayout Spacing="4">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Roll Log" FontFamily="Faustina-Bold.ttf"
                                FontSize="16" TextColor="{StaticResource TextDark}"/>
                            <Label Grid.Column="1" Text="Hide" FontSize="12"
                                TextColor="{StaticResource TextMid}">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnRollLogToggled"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>
                        <ScrollView MaximumHeightRequest="160" Margin="0,4,0,0">
                            <CollectionView x:Name="RollLogList">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Label Text="{Binding .}"
                                            Style="{StaticResource ItemSubtitleText}"
                                            Margin="4,2"/>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </ScrollView>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="6" Margin="0,0,0,12">
                <Label Text="Recent Homebrew" Style="{StaticResource SectionHeader}"/>
                <Border Style="{StaticResource CardOuter}" Margin="0,4">
                    <CollectionView x:Name="RecentHomebrewList" SelectionMode="None" MinimumHeightRequest="150">
                        <CollectionView.EmptyView>
                            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                                <Label Text="You currently don't have any homebrew"
                                       Style="{StaticResource ItemSubtitle}" Margin="0,4,4,0"
                                       HorizontalOptions="Center" VerticalOptions="Center"
                                       HorizontalTextAlignment="Center"
                                       TextColor="White" FontSize="18"/>
                                <Button Text="CREATE HOMEBREW" Style="{StaticResource RollBtn}" Padding="20, 10" 
                                        FontFamily="Commissioner-Bold.ttf" FontSize="15" HorizontalOptions="Center" Clicked="GoToNewCreation"/>
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardInner}" Margin="0,4">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnHomebrewTapped" />
                                    </Border.GestureRecognizers>
                                    
                                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="15" Padding="8">
                                        <Image Grid.Column="0"
                                               Source="{Binding TypeIconIMGSource}"
                                               HeightRequest="40"
                                               WidthRequest="40"
                                               VerticalOptions="Center"
                                               HorizontalOptions="Center"/>
                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                            <Label Text="{Binding Title}" Style="{StaticResource ItemTitle}" TextColor="#4F6367"/>
                                            <Label Text="{Binding CreationType}" Style="{StaticResource ItemSubtitle}" TextColor="#4F6367"/>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Border>    
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentView>