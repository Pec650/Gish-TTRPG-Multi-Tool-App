<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Gish.Pages.MainPages.CreationsPage"
             Title="Creations"
             BackgroundColor="{StaticResource TabBar}">
    
    <Grid RowDefinitions="Auto,*">

        <!-- HEADER -->
        <Grid Grid.Row="0"
              x:Name="Header"
              Padding="16,32,16,16"
              ColumnDefinitions="*,Auto">
            <Label Style="{StaticResource PageTitle}"
                   Text="Your Homebrew Creations"
                   TextColor="{StaticResource TextDark}"
                   VerticalOptions="Center"/>
            <HorizontalStackLayout Grid.Column="1" Spacing="10" VerticalOptions="Center">
                <Image Source="profile_icon.png" WidthRequest="36" HeightRequest="36"/>
                <Label Text="≡" FontSize="26" TextColor="{StaticResource TextDark}" VerticalOptions="Center"/>
            </HorizontalStackLayout>
        </Grid>
        
        <ScrollView Grid.Row="1"
                    BackgroundColor="{StaticResource PageBackground}">
            <VerticalStackLayout Padding="20" Spacing="20">
                <Label Style="{StaticResource SubTitle}" Text="Creations" />
                <Label Text="Your homebrew content will live here" FontSize="18" HorizontalOptions="Center" />
            </VerticalStackLayout>
        </ScrollView>
        
    </Grid>
</ContentPage>