<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Gish.Pages.MainPages.Profile_Pages.ProfilePage"
             Title="Profile"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource TabBar}">             
    
    <Grid RowDefinitions="Auto,*">
    
        <!-- HEADER -->
        <Grid Grid.Row="0"
              x:Name="Header"
              Padding="16,32,16,16"
              ColumnDefinitions="*,Auto">
            
            <HorizontalStackLayout Spacing="10">
                <ImageButton x:Name="ReturnButton"
                             Source="back_button.png"
                             HeightRequest="40"
                             WidthRequest="40"
                             HorizontalOptions="Start"
                             VerticalOptions="Center"
                             Clicked="ReturnPage"
                             Grid.Column="1"></ImageButton>
                <Label Style="{StaticResource PageTitle}"
                       Text="Profile"
                       TextColor="{StaticResource TextDark}"
                       VerticalOptions="Center"/>
            </HorizontalStackLayout>
        </Grid>
    
        <ScrollView Grid.Row="1"
                    BackgroundColor="{StaticResource PageBackground}"
                    VerticalOptions="Fill">
            <VerticalStackLayout Padding="20" Spacing="20" VerticalOptions="Fill">
                
                <ImageButton x:Name="ProfilePictureImage"
                             Source="profile_icon.svg"
                             Style="{StaticResource ProfilePicture}"
                             HeightRequest="150"
                             WidthRequest="150"
                             BorderWidth="8"
                             HorizontalOptions="Center"
                             Margin="0, 10, 0, 0"/>
        
                <Label x:Name="UsernameText" Text="Username"
                       Style="{StaticResource ProfileUsername}"
                       HorizontalTextAlignment="Center" />
                
                <Label x:Name="EmailText" Text="Email Address"
                       Style="{StaticResource ProfileEmail}"
                       HorizontalTextAlignment="Center"
                       Margin="0, 0, 0, 10"/>
                
                <VerticalStackLayout VerticalOptions="End" Spacing="20">
                    <Button x:Name="EditProfileButton"
                            Text="Edit Profile"
                            Style="{StaticResource ToolsButton}"
                            Clicked="GoToEditProfile"/>
                    <Button x:Name="ChangePasswordButton"
                            Text="Change Password"
                            Style="{StaticResource ToolsButton}"/>
                    <Button x:Name="LogOutButton"
                            Text="Log Out"
                            Style="{StaticResource ToolsButton}"
                            BackgroundColor="#FE5F55"
                            TextColor="White"
                            BorderWidth="0"
                            Clicked="LogOut"/>
                </VerticalStackLayout>
                
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>