<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Gish.Pages.Main_Pages.Profile_Pages.ChangePasswordPage"
             Title="Change Password"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource TabBar}">
    <Grid RowDefinitions="Auto,*">
    
        <!-- HEADER -->
        <Grid Grid.Row="0"
              x:Name="Header"
              Padding="16,32,16,16"
              ColumnDefinitions="*,Auto">
            
            <HorizontalStackLayout Spacing="10">
                <ImageButton x:Name="ReturnButton"
                             Source="back_button.png"
                             HeightRequest="40"
                             WidthRequest="40"
                             HorizontalOptions="Start"
                             VerticalOptions="Center"
                             Clicked="ReturnPage"
                             Grid.Column="1"></ImageButton>
            </HorizontalStackLayout>
        </Grid>
    
        <ScrollView Grid.Row="1"
                    BackgroundColor="{StaticResource PageBackground}"
                    VerticalOptions="Fill">
            <VerticalStackLayout Padding="20" Spacing="20" VerticalOptions="Start">
                    
                <Label Text="Update Password"
                       Margin="0, 50, 0, 20"
                       Style="{StaticResource TitleText}"
                       FontSize="35"></Label>
                
                <!-- NEW PASSWORD INPUT -->
                <Label Text="Password" Style="{StaticResource InputTextLabel}"></Label>
                    
                <Border Style="{StaticResource InputTextEntryBorder}"
                        Margin="0, 10, 0, 10">
                    <Grid ColumnDefinitions="0.9*, 0.1*">
                        <Entry x:Name="PasswordInput"
                               Placeholder="Enter new password"
                               Keyboard="Default"
                               IsPassword="True"
                               ReturnType="Go"
                               TextChanged="InputChanged"
                               Grid.Column="0"
                               Style="{StaticResource InputTextEntry}"></Entry>
                        <ImageButton x:Name="TogglePasswordBtn"
                                     Style="{StaticResource PasswordEyeIcon}"
                                     Grid.Column="1"
                                     Clicked="ToggleShowPassword"/>
                    </Grid>
                </Border>
                
                <!-- NEW CONFIRM PASSWORD INPUT -->
                <Label Text="Confirm Password" Style="{StaticResource InputTextLabel}"></Label>
                    
                <Border Style="{StaticResource InputTextEntryBorder}"
                        Margin="0, 10, 0, 10">
                    <Grid ColumnDefinitions="0.9*, 0.1*">
                        <Entry x:Name="ConfirmPassInput"
                               Placeholder="Re-enter password"
                               Keyboard="Default"
                               IsPassword="True"
                               ReturnType="Go"
                               TextChanged="InputChanged"
                               Grid.Column="0"
                               Style="{StaticResource InputTextEntry}"></Entry>
                        <ImageButton x:Name="ToggleConfirmPasswordBtn"
                                     Style="{StaticResource PasswordEyeIcon}"
                                     Grid.Column="1"
                                     Clicked="ToggleShowConfirmPassword"/>
                    </Grid>
                </Border>
                
                <!-- ERROR MESSAGE -->
                <Label x:Name="InputError" IsVisible="False"
                       Margin="0, -5, 0, -5"
                       Style="{StaticResource InputErrorText}"></Label>
                
                <!-- SUBMIT BUTTON -->
                <Button x:Name="SubmitBtn"
                        Text="Confirm"
                        Margin="0, 10"
                        Style="{StaticResource RedBtn}"
                        Clicked="ConfirmChange"/>
                
                <ActivityIndicator x:Name="LoadingIndicator" IsRunning="False" VerticalOptions="Center" />
                
            </VerticalStackLayout>
        </ScrollView>
        
    </Grid>
</ContentPage>