<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Gish.Pages.Main_Pages.Profile_Pages.EditProfilePage"
             Title="Edit Profile"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource TabBar}">
    
    <Grid RowDefinitions="Auto,*">
    
        <!-- HEADER -->
        <Grid Grid.Row="0"
              x:Name="Header"
              Padding="16,32,16,16"
              ColumnDefinitions="*,Auto">
            
            <HorizontalStackLayout Spacing="10">
                <ImageButton x:Name="ReturnButton"
                             Source="back_button.png"
                             HeightRequest="40"
                             WidthRequest="40"
                             HorizontalOptions="Start"
                             VerticalOptions="Center"
                             Clicked="ReturnPage"
                             Grid.Column="1"></ImageButton>
                <Label Style="{StaticResource PageTitle}"
                       Text="Edit Profile"
                       TextColor="{StaticResource TextDark}"
                       VerticalOptions="Center"/>
            </HorizontalStackLayout>
        </Grid>
        
        <ScrollView Grid.Row="1"
                    BackgroundColor="{StaticResource PageBackground}"
                    VerticalOptions="Fill">
            <VerticalStackLayout Padding="20" Spacing="20" VerticalOptions="Fill">
                
                <!-- PROFILE PICTURE INPUT -->
                <Label Text="Profile Picture" Style="{StaticResource InputTextLabel}"></Label>
                <Border Style="{StaticResource ProfileBorder}"
                        HeightRequest="150"
                        WidthRequest="150"
                        Margin="0, 10, 0, 0"
                        StrokeThickness="8">
                    <ImageButton x:Name="ProfilePictureInput"
                                 Style="{StaticResource ProfilePictureButton}"
                                 Clicked="OnSelectFileClicked"/>
                </Border>
                
                <Label Text="Edit Profile"
                       Style="{StaticResource InputTextLabel}"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       Margin="0, -10, 0, 0"></Label>
                
                <VerticalStackLayout VerticalOptions="End" Spacing="20">
                    
                    <!-- USERNAME INPUT -->
                    <Label Text="Username" Style="{StaticResource InputTextLabel}"></Label>
                    <Border Style="{StaticResource InputTextEntryBorder}"
                            Margin="0, 10, 0, 10">
                        <Entry x:Name="UsernameInput"
                               Placeholder="Enter username"
                               Keyboard="Email"
                               ReturnType="Next"
                               Style="{StaticResource InputTextEntry}"></Entry>
                    </Border>
                    
                    <!-- ERROR MESSAGE -->
                    <Label x:Name="InputError" IsVisible="False"
                           Margin="0, -5, 0, -5"
                           Style="{StaticResource InputErrorText}"></Label>
                
                    <!-- SUBMIT BUTTON -->
                    <Button x:Name="SubmitBtn"
                            Text="Confirm"
                            Margin="0, 10"
                            Style="{StaticResource RedBtn}"
                            Clicked="ConfirmChange"/>
                    
                    <ActivityIndicator x:Name="LoadingIndicator" IsRunning="False" VerticalOptions="Center" />
                    
                </VerticalStackLayout>
                
            </VerticalStackLayout>
        </ScrollView>
        
    </Grid>    
</ContentPage>