<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Gish.Pages.ToolPages.SchedulerView"
             BackgroundColor="{StaticResource PageBackground}">

    <Grid RowDefinitions="Auto, *, Auto" Padding="0" RowSpacing="0">
        
        <Border Grid.Row="0" BackgroundColor="#E8A984" HeightRequest="60" Stroke="Transparent" Margin="0">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <ImageButton Source="back_arrow_icon.png" 
                             WidthRequest="24" HeightRequest="24" 
                             Margin="16,0" VerticalOptions="Center"
                             Clicked="OnBackClicked"/>
                <Label Grid.Column="1" Text="Session Reminder" 
                       FontFamily="Faustina-Bold.ttf" FontSize="20" 
                       TextColor="#424C44" VerticalOptions="Center"/>
                <ImageButton Grid.Column="2" Source="add_icon.png" 
                             WidthRequest="24" HeightRequest="24" 
                             Margin="16,0" VerticalOptions="Center" 
                             Clicked="OnCreateSessionClicked"/>
            </Grid>
        </Border>

        <ScrollView Grid.Row="1" Padding="20,10">
            <VerticalStackLayout Spacing="15">
                
                <Grid ColumnDefinitions="Auto, *, Auto" HorizontalOptions="Fill" Margin="0,10">
                    <ImageButton Grid.Column="0" Source="left_chevron.png" WidthRequest="20" Clicked="OnPreviousMonthClicked"/>
                    <Border Grid.Column="1" StrokeShape="RoundRectangle 4" BackgroundColor="White" Padding="20,6" HorizontalOptions="Center">
                        <Label x:Name="MonthYearLabel" Text="May 2026" FontFamily="Faustina-Bold.ttf" FontSize="16" TextColor="#5D6660"/>
                    </Border>
                    <ImageButton Grid.Column="2" Source="right_chevron.png" WidthRequest="20" Clicked="OnNextMonthClicked"/>
                </Grid>

                <Grid x:Name="CalendarGrid" 
                      ColumnDefinitions="*,*,*,*,*,*,*" 
                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" 
                      ColumnSpacing="6" RowSpacing="6"
                      HorizontalOptions="Fill"/>
            </VerticalStackLayout>
        </ScrollView>

        <Border Grid.Row="2" 
                x:Name="DetailsDrawer"
                IsVisible="False"
                BackgroundColor="#E8A984" 
                StrokeShape="RoundRectangle 24,24,0,0" 
                Padding="20" Margin="0" VerticalOptions="End">
            <VerticalStackLayout Spacing="12">
                
                <Grid ColumnDefinitions="*, Auto" Margin="5,0">
                    <Label x:Name="DrawerHeaderLabel" Text="Sessions for this Day" FontFamily="Faustina-Bold.ttf" FontSize="18" TextColor="#1E2420" VerticalOptions="Center"/>
                    <Button Grid.Column="1" Text="+ Add Session" BackgroundColor="#1E2420" TextColor="White" FontAttributes="Bold" CornerRadius="8" Padding="12,0" Clicked="OnDrawerAddSessionClicked"/>
                </Grid>

                <ScrollView MaxHeightRequest="200">
                    <VerticalStackLayout x:Name="DrawerSessionsContainer" Spacing="10" Padding="0,5"/>
                </ScrollView>
                
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentView>