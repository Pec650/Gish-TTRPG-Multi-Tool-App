<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Gish.Pages.Controls"
             x:Class="Gish.Pages.Creations_Pages.NewCreationPage">
    <ContentPage.Content>
        
        <Grid RowDefinitions="Auto,*" Padding="0" RowSpacing="0" Margin="0">

            <controls:CustomHeader Grid.Row="0" Title="Create New" />
            
            <ScrollView Grid.Row="1"
                        BackgroundColor="{StaticResource PageBackground}"
                        VerticalOptions="Fill"
                        HorizontalOptions="Fill">
                <VerticalStackLayout Padding="20" Spacing="20">
                    
                    <Label Style="{StaticResource SubTitle}" Text="Creation Title" HorizontalOptions="Start" />
                    
                    <Border Style="{StaticResource InputTextEntryBorder}">
                        <Entry x:Name="NameInput" Placeholder="Enter title" ReturnType="Done" Style="{StaticResource InputTextEntry}"/>
                    </Border>
                    
                    <Label Style="{StaticResource SubTitle}" Text="Metadata" HorizontalOptions="Start" />
                    
                    <Label Style="{StaticResource SubTitle}" Text="Description" HorizontalOptions="Start" />
                    
                    <Label Style="{StaticResource SubTitle}" Text="Features" HorizontalOptions="Start" />
                    
                </VerticalStackLayout>
            </ScrollView>
            
        </Grid>    
    </ContentPage.Content>
</ContentPage>