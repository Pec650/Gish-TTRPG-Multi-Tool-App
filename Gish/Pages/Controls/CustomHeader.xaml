<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Gish.Pages.Controls.CustomHeader">

    <Border BackgroundColor="#FEC7A2"
            Stroke="Transparent"
            Padding="16,0"
            HeightRequest="64"
            Margin="0"
            VerticalOptions="Start">
        
        <Grid ColumnDefinitions="*, Auto" RowSpacing="0">
            
            <Label x:Name="HeaderTitleLabel"
                   Text="{Binding Title, Source={RelativeSource AncestorType={x:Type ContentView}}}"
                   Style="{StaticResource PageTitle}"
                   TextColor="{StaticResource TextDark}"
                   VerticalOptions="Center"
                   VerticalTextAlignment="Center"/>

            <HorizontalStackLayout Grid.Column="1" Spacing="10" VerticalOptions="Center">
                <Border HeightRequest="36" 
                        WidthRequest="36" 
                        Style="{StaticResource ProfileBorder}">
                    <ImageButton x:Name="ProfileBtn"
                                 Style="{StaticResource ProfilePictureButton}"
                                 Clicked="OnProfileClicked"/>
                </Border>
            </HorizontalStackLayout>
        </Grid>
    </Border>
</ContentView>