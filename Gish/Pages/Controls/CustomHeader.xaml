<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Gish.Pages.Controls.CustomHeader">

    <Border BackgroundColor="{StaticResource TabBar}"
            Stroke="Transparent"
            Padding="16,0"
            HeightRequest="120"
            Margin="0"
            VerticalOptions="End">
        
        <Grid ColumnDefinitions="Auto, *, Auto" RowSpacing="0" ColumnSpacing="12">
            
            <ImageButton x:Name="BackBtn" 
                         Grid.Column="0"
                         Source="back_button.png" 
                         WidthRequest="24" 
                         HeightRequest="24" 
                         VerticalOptions="Center"
                         IsVisible="False"
                         Clicked="OnBackClicked"/>
            
            <Label x:Name="HeaderTitleLabel" 
                   Grid.Column="1"
                   Text="{Binding Title, Source={RelativeSource AncestorType={x:Type ContentView}}}"
                   Style="{StaticResource PageTitle}"
                   TextColor="{StaticResource TextDark}"
                   VerticalOptions="Center"
                   VerticalTextAlignment="Center"/>

            <HorizontalStackLayout Grid.Column="2" Spacing="10" VerticalOptions="Center">
                <Border x:Name="ProfileBorderContainer"
                        HeightRequest="36" 
                        WidthRequest="36" 
                        Style="{StaticResource ProfileBorder}">
                    <ImageButton x:Name="ProfileBtn"
                                 Style="{StaticResource ProfilePictureButton}"
                                 Clicked="OnProfileClicked"/>
                </Border>
            </HorizontalStackLayout>
        </Grid>
    </Border>
</ContentView>